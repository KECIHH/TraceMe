{
  "name": "traceme",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "start:e2e": "node scripts/prepare-standalone-e2e.mjs && node scripts/ensure-sqlite-db.mjs && prisma migrate deploy && node scripts/seed-admin.mjs && node scripts/start-standalone-e2e.mjs",
    "validate:env": "node scripts/validate-production-env.mjs",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:ensure": "node scripts/ensure-sqlite-db.mjs",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node scripts/seed-admin.mjs",
    "db:studio": "prisma studio",
    "backup:create": "tsx scripts/backup.ts create",
    "backup:list": "tsx scripts/backup.ts list",
    "backup:verify": "tsx scripts/backup.ts verify",
    "backup:restore": "tsx scripts/backup.ts restore",
    "backup:prune": "tsx scripts/backup.ts prune",
    "documents:migrate-encryption": "tsx scripts/migrate-documents-encryption.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "16.2.6",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
