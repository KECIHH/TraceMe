DATABASE_URL="file:./dev.db"
# Production domains must use HTTPS, for example https://travel.example.com.
# Temporary IP testing may use http://SERVER_IP:3000 before HTTPS is ready.
# Local development may use http://localhost:3000.
APP_BASE_URL="https://travel.example.com"
SESSION_SECRET="replace-with-a-long-random-secret"
INITIAL_ADMIN_USERNAME="admin"
INITIAL_ADMIN_PASSWORD="change-me-before-use"

# Optional
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
AI_PROVIDER="openai"
AI_FEATURE_ENABLED="true"
# Required if API keys are configured from /settings/ai instead of environment variables.
AI_CONFIG_ENCRYPTION_KEY=""
# Stage 17 external providers. Use "none" or "mock" when no external API is configured.
MAP_PROVIDER="none"
# Only expose a browser map key when the provider requires it, and restrict it by domain in the provider console.
NEXT_PUBLIC_MAP_PROVIDER=""
MAP_PUBLIC_API_KEY_EXPOSED="false"
WEATHER_PROVIDER="none"
EXCHANGE_RATE_PROVIDER="none"
OPEN_EXCHANGE_RATES_APP_ID=""
# Required in production. Losing or changing this key makes encrypted uploads unrecoverable.
DOCUMENT_ENCRYPTION_KEY=""
AUDIT_LOG_IP_SALT=""
BACKUP_KEEP_DAILY="7"
BACKUP_KEEP_WEEKLY="4"
ALLOW_SEARCH_INDEXING="false"
SEED_EXAMPLE_TRIP="true"
TRACEME_BIND="127.0.0.1"
TRACEME_PORT="3000"
TRACEME_IMAGE="ghcr.io/kecihh/traceme:main"
TRACEME_USE_LOCAL_BUILD="false"
NPM_CONFIG_REGISTRY="https://registry.npmjs.org/"
ALPINE_REPOSITORY_MIRROR=""
BUILD_NODE_OPTIONS="--max-old-space-size=1024"
